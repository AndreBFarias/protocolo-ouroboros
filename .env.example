# Template do `.env` para protocolo-ouroboros
# Sprint SEC-SENHAS-PARA-ENV (2026-05-17)
#
# 1. Copie para `.env` (gitignored): `cp .env.example .env`
# 2. Preencha os valores com suas credenciais reais.
# 3. Nunca commite `.env` (já está em `.gitignore`).
#
# Carregado por src/utils/segredos.py em runtime.

# ─────────────────────────────────────────────────────────
# Senhas de PDFs bancários protegidos
# ─────────────────────────────────────────────────────────
# Usadas por extratores: itau_pdf.py, c6_cartao.py, c6_cc.py.
# A função `senhas_pdf()` em src/utils/segredos.py tenta cada senha
# em ordem até uma desbloquear o PDF.

PDF_SENHA_PRIMARIA=
PDF_SENHA_SECUNDARIA=
PDF_SENHA_CPF=

# Senhas adicionais opcionais (qualquer PDF_SENHA_* é considerado):
# PDF_SENHA_C6=
# PDF_SENHA_SANTANDER=

# ─────────────────────────────────────────────────────────
# Paths (opcional)
# ─────────────────────────────────────────────────────────
# Caminho do vault Obsidian para integração (Fase IOTA).
# Default usado por src/integrations/controle_bordo.py se ausente.

# OBSIDIAN_VAULT=/home/user/Documents/Vault
# PROJETO_DIR=/home/user/Desenvolvimento/protocolo-ouroboros

# ─────────────────────────────────────────────────────────
# Override de comportamento (opcional)
# ─────────────────────────────────────────────────────────
# Path do cache de sync do Obsidian para testes (sprint INFRA-TEST-ISOLAR-LAST-SYNC).
# Default: <projeto>/.ouroboros/cache/.

# OUROBOROS_CACHE_DIR=

# Lista de extratores a desabilitar via env (sprint INFRA-DESCOBRIR-EXTRATORES-REFATORA, futuro).
# Exemplo: OUROBOROS_EXTRATORES_DESABILITADOS=das_parcsn_pdf,nfce_pdf

# OUROBOROS_EXTRATORES_DESABILITADOS=

# Timeout (segundos) para abertura de PDF via pdfplumber (sprint INFRA-PDF-TIMEOUT, futuro).
# Default: 30.

# OUROBOROS_PDF_TIMEOUT=30
